# GitHub Personal Access Token with public_repo / repo read scope (required)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx

# Ollama server (local, free open-source LLM). Default works after `ollama serve`.
OLLAMA_HOST=http://localhost:11434

# SQLite database path
DB_PATH=./reviewer.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Models to pull in Ollama (cheap default pass / deep pass for hard cases)
MODEL_DEFAULT=qwen2.5-coder:7b
MODEL_DEEP=qwen2.5-coder:14b
